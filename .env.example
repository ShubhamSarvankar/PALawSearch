# Copy this file to .env and fill in real values. Never commit .env.

# Elasticsearch — required, no default; missing value raises ValidationError at startup
ES_PASSWORD=your-new-es-password-here
ES_HOST=https://localhost:9200

# Redis (optional, defaults shown)
REDIS_HOST=localhost
REDIS_PORT=6379

# Phase 4 LLM judge — required, no default; missing value raises ValidationError at startup
ANTHROPIC_API_KEY=sk-ant-...
